{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "composite": true,
    "incremental": true,
    "newLine": "lf",
    "verbatimModuleSyntax": true,
    "isolatedModules": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "noImplicitOverride": true,
    "noFallthroughCasesInSwitch": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "rootDir": ".",
    "baseUrl": ".",
    "paths": {
      "@kaiisuuwii/shared": [
        "packages/shared/src/index.ts"
      ],
      "@kaiisuuwii/core": [
        "packages/core/src/index.ts"
      ],
      "@kaiisuuwii/renderer-skia": [
        "packages/renderer-skia/src/index.ts"
      ],
      "@kaiisuuwii/renderer-svg": [
        "packages/renderer-svg/src/index.ts"
      ],
      "@kaiisuuwii/renderer-web": [
        "packages/renderer-web/src/index.ts"
      ],
      "@kaiisuuwii/examples": [
        "packages/examples/src/index.ts"
      ],
      "@kaiisuuwii/plugins": [
        "packages/plugins/src/index.ts"
      ],
      "@kaiisuuwii/docs": [
        "packages/docs/src/index.ts"
      ],
      "@kaiisuuwii/react-native": [
        "packages/react-native/src/index.ts"
      ],
      "@kaiisuuwii/layout": [
        "packages/layout/src/index.ts"
      ],
      "@kaiisuuwii/sync": [
        "packages/sync/src/index.ts"
      ],
      "@kaiisuuwii/persistence": [
        "packages/persistence/src/index.ts"
      ]
    }
  }
}
