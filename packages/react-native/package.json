{
  "name": "@kaiisuuwii/react-native",
  "version": "0.2.0",
  "private": false,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "files": [
    "dist",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/KaiSuuWii/react-native-node-graph.git"
  },
  "license": "MIT",
  "homepage": "https://github.com/KaiSuuWii/react-native-node-graph",
  "bugs": {
    "url": "https://github.com/KaiSuuWii/react-native-node-graph/issues"
  },
  "keywords": [
    "graph",
    "react-native",
    "gestures",
    "skia",
    "reanimated"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run packages/react-native/tests"
  },
  "dependencies": {
    "@kaiisuuwii/core": "0.1.0",
    "@kaiisuuwii/renderer-skia": "0.1.0",
    "@kaiisuuwii/shared": "0.1.0"
  },
  "peerDependencies": {
    "@shopify/react-native-skia": ">=1.2.0",
    "react": ">=18",
    "react-native": ">=0.73",
    "react-native-gesture-handler": ">=2.14.0",
    "react-native-reanimated": ">=3.6.0"
  }
}
