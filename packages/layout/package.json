{
  "name": "@kaiisuuwii/layout",
  "version": "0.2.0",
  "private": false,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "files": [
    "dist",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/KaiSuuWii/react-native-node-graph.git"
  },
  "license": "MIT",
  "homepage": "https://github.com/KaiSuuWii/react-native-node-graph",
  "bugs": {
    "url": "https://github.com/KaiSuuWii/react-native-node-graph/issues"
  },
  "keywords": [
    "graph",
    "layout",
    "auto-layout",
    "react-native"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run packages/layout/tests",
    "benchmark": "vitest run packages/layout/benchmarks/layout-benchmark.ts"
  },
  "dependencies": {
    "@kaiisuuwii/shared": "0.1.0"
  }
}
