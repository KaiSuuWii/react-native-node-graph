{
  "name": "react-native-node-graph",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/KaiSuuWii/react-native-node-graph.git"
  },
  "license": "MIT",
  "homepage": "https://github.com/KaiSuuWii/react-native-node-graph",
  "bugs": {
    "url": "https://github.com/KaiSuuWii/react-native-node-graph/issues"
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "tsc -b tsconfig.build.json",
    "typecheck": "tsc -b tsconfig.json",
    "lint": "eslint . --ext .ts --max-warnings=0",
    "test": "vitest run",
    "test:integration": "vitest run packages/examples/tests/integration.test.ts packages/docs/tests/smoke.test.ts",
    "test:renderer-theme": "vitest run packages/renderer-skia/tests/theme.test.ts packages/renderer-skia/tests/scene.test.ts",
    "benchmark:renderer": "vitest run packages/renderer-skia/tests/performance-benchmark.test.ts",
    "release:check": "npm run typecheck && npm run lint && npm run test && npm run benchmark:renderer",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "clean": "node --eval \"import('node:fs/promises').then(async fs => { for (const dir of ['packages/core/dist','packages/renderer-skia/dist','packages/renderer-svg/dist','packages/renderer-web/dist','packages/shared/dist','packages/examples/dist','packages/plugins/dist','packages/docs/dist','coverage']) { await fs.rm(dir, { recursive: true, force: true }); } })\""
  },
  "devDependencies": {
    "@types/node": "^24.0.1",
    "@typescript-eslint/eslint-plugin": "^8.31.1",
    "@typescript-eslint/parser": "^8.31.1",
    "eslint": "^9.26.0",
    "eslint-config-prettier": "^10.1.2",
    "prettier": "^3.5.3",
    "typescript": "^5.8.3",
    "vitest": "^3.1.3"
  }
}
